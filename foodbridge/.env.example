# ─── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# ─── AI ────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ─── Maps ──────────────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ─── Weather ───────────────────────────────────────────────────────────────────
OPENWEATHER_API_KEY=

# ─── Firebase (push notifications) ────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ─── n8n Automation ────────────────────────────────────────────────────────────
N8N_WEBHOOK_BASE_URL=
N8N_API_KEY=

# ─── Frontend (public — safe to expose to browser) ────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# ─── API server ────────────────────────────────────────────────────────────────
# CORS_ORIGIN: frontend URL that the API server allows cross-origin requests from
CORS_ORIGIN=http://localhost:3000
